	<script>
		function updateCurrentPrice(p,t) {
			$('#currentPrice').text(p + "p");
			$('#currentPriceTime').text(t);
			if (p < 0) {
				$('#currentPrice').removeClass('text-danger').addClass('text-success');
			} else {
				$('#currentPrice').removeClass('text-success');
			}
		}

		function updateCheapestPrice(p,t) {
			$('#cheapestPrice').text(p + "p");
			$('#cheapestPriceTime').text(t);
		}

		function updateMostExpensivePrice(p,t) {
			$('#mostExpensivePrice').text(p + "p");
			$('#mostExpensivePriceTime').text(t);
		}

		function updatePriceTable(prices, currentDay = true) {
			$('#priceTable tbody').empty();

			let rowStyle = "";
			let priceStyle = "";
			prices.forEach(price => {
				rowStyle = (price.time === getCurrentTimePeriod() && currentDay === true) ? "table-primary" : "";
				priceStyle = (price.price < 0) ? "text-success" : "";

				$('#priceTable tbody').append(`<tr class="${rowStyle}"><th scope="row">${price.time}</th><td class="${priceStyle}">${price.price}p</td></tr>`);
			});
		}

		function getCurrentTimePeriod() {
			const now = new Date();
			const hours = String(now.getHours()).padStart(2, '0');
			const minutes = now.getMinutes() < 30 ? '00' : '30';
			const endMinutes = minutes === '00' ? '30' : '00';
			const endHours = endMinutes === '00' ? String((now.getHours() + 1) % 24).padStart(2, '0') : String(now.getHours()).padStart(2, '0');
			return `${hours}:${minutes} - ${endHours}:${endMinutes}`;
		}

		function findCurrentPrice(prices) {
			for (let i = 0; i < prices.length; i++) {
				if (prices[i].time === getCurrentTimePeriod()) {
					return prices[i];
				}
			}
			return null; // Return null if no current price is found
		}

		function isLondonInDST() {
			// This isn't actually used, but keeping it here in case it becomes useful in the future
			const january = new Date(Date.UTC(2026, 0, 1)); // January 1st, 2026 (Winter, Standard Time)
			const july = new Date(Date.UTC(2026, 6, 1));    // July 1st, 2026 (Summer, DST)

			// Get the offset for UTC in minutes for both dates
			const januaryOffset = january.getTimezoneOffset();
			const julyOffset = july.getTimezoneOffset();

			// DST is active if the offset for July is different (typically 60 minutes less)
			return julyOffset < januaryOffset;
		}

		function calculateUrl(day = "today") {
			const fromDate = new Date();
				fromDate.setHours(0, 0, 0, 0); // Set h, m, s, ms to midnight UTC
			const toDate = new Date(fromDate);
				toDate.setHours(toDate.getHours() + 24); // Set to 24 hours in the future

			// Add 24h if the user wants to see tomorrow's prices
			if (day === "tomorrow") {
				fromDate.setHours(fromDate.getHours() + 24);
				toDate.setHours(toDate.getHours() + 24);
			}

			// Format as ISO string and remove milliseconds
			const periodFrom = fromDate.toISOString().split(".")[0] + "Z";
			const periodTo = toDate.toISOString().split(".")[0] + "Z";

			return `https://api.octopus.energy/v1/products/AGILE-24-10-01/electricity-tariffs/E-1R-AGILE-24-10-01-J/standard-unit-rates/?period_from=${periodFrom}&period_to=${periodTo}`;
		}

		$("button").click(async function() {
			if ($(this).text() == "") return; // Ensure the button is not already loading

			const spinner = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span>';
			const textContent = $(this).text();

			const dataTarget = $(this).data("target");
			const fetchUrl = calculateUrl(dataTarget);

			$(this).html(spinner);


			const prices = [];

			fetch(fetchUrl)
				.then(async function(response) {
					const data = await response.json();

					if (data.results.length === 0) {
						throw new Error("No price data available");
					}

					$("button").removeClass("active");

					data.results.forEach(result => {
						const roundedPrice = Math.round(result.value_inc_vat * 100) / 100;
						const sanitizedTime = new Date(result.valid_from).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) + " - " + new Date(result.valid_to).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
						prices.push({
							price: roundedPrice,
							time: sanitizedTime
						});
					});

					// Order the prices by time from earliest to latest
					prices.sort((a, b) => new Date(a.time.split(" - ")[0]) - new Date(b.time.split(" - ")[0]));
					prices.reverse(); // Reverse the order to have the latest price first

					// Loop through prices and find the cheapest price
					let lowestPrice = prices[0];
					let highestPrice = prices[0];
					prices.forEach(price => {
						if (price.price < lowestPrice.price) {
							lowestPrice = price;
						}
						if (price.price > highestPrice.price) {
							highestPrice = price;
						}
					});

					updateCheapestPrice(lowestPrice.price, lowestPrice.time);
					updateMostExpensivePrice(highestPrice.price, highestPrice.time);
					if (dataTarget === "today") {
						updatePriceTable(prices);

						const currentPrice = findCurrentPrice(prices);
						(currentPrice) ? updateCurrentPrice(currentPrice.price, currentPrice.time) : updateCurrentPrice("N/A", "N/A");
					} else {
						updatePriceTable(prices, false);
					}

				})
				.then(() => {
					$(this).addClass("active");
				})
				.catch(error => console.error('Error fetching data:', error))
				.finally(() => {
					$(this).html(textContent);
				});
		});

		// Populate the page with today's prices on load
		$("#getPrices").click();
	</script>
